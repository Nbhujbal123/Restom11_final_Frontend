# Environment Variables for RestoM Frontend
# Copy this file to .env and update the values

# Backend API URL (required for production)
VITE_API_BASE_URL=https://restom11-final-backend.onrender.com/api

# Frontend URL (required for production)
VITE_FRONTEND_URL=https://restom11-final-frontend.onrender.com

# For local development, you can use:
# VITE_API_BASE_URL=http://localhost:5000/api
# VITE_FRONTEND_URL=http://localhost:5173
